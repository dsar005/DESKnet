<section class="section section--alt">
  <div class="container">
    <div class="section__header animate-on-scroll">
      <span class="section__eyebrow">Featured Products</span>
      <h2 class="section__title">Elevate Your Workspace</h2>
      <p class="section__subtitle">Hand-picked essentials that transform any desk into a productivity powerhouse.</p>
    </div>

    <div class="featured-products__grid">
      {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
        <div class="animate-on-scroll animate-delay-{{ forloop.index }}">
          {% render 'product-card', product: product %}
        </div>
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="animate-on-scroll animate-delay-{{ forloop.index }}">
            {% render 'product-card-placeholder', index: forloop.index %}
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <div class="text-center" style="margin-top:var(--sp-12)">
      <a href="/collections/all" class="btn btn--secondary btn--lg">
        View All Products
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 8, "step": 1, "label": "Products to show", "default": 4 }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
