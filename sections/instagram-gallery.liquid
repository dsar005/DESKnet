<section class="section section--alt">
  <div class="container">
    <div class="section__header animate-on-scroll">
      <span class="section__eyebrow">@desknet</span>
      <h2 class="section__title">Tag Us In Your Setup</h2>
      <p class="section__subtitle">Share your workspace with <strong>#DESKnetSetup</strong> for a chance to be featured. Join thousands in the community.</p>
    </div>

    <div class="instagram__grid animate-on-scroll">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'image' -%}
          <a href="{{ block.settings.url | default: 'https://instagram.com/desknet' }}" class="instagram__item" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img class="instagram__img" src="{{ block.settings.image | image_url: width: 400 }}" alt="DESKnet setup" loading="lazy">
            {%- else -%}
              <div class="instagram__placeholder">{{ block.settings.emoji | default: '🖥️' }}</div>
            {%- endif -%}
            <div class="instagram__overlay">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
            </div>
          </a>
        {%- endcase -%}
      {%- else -%}
        <!-- Default placeholder gallery -->
        {%- assign emojis = "🖥️,💻,⌨️,🖱️,💡,📐" | split: "," -%}
        {%- for emoji in emojis -%}
          <div class="instagram__item animate-on-scroll animate-delay-{{ forloop.index }}">
            <div class="instagram__placeholder" style="background:
              {%- case forloop.index -%}
              {%- when 1 -%}linear-gradient(135deg,#f0f0ee,#ddd)
              {%- when 2 -%}linear-gradient(135deg,#e8e8f0,#d8d8e8)
              {%- when 3 -%}linear-gradient(135deg,#f0eef0,#e0d8e0)
              {%- when 4 -%}linear-gradient(135deg,#eef0f0,#d8e0e0)
              {%- when 5 -%}linear-gradient(135deg,#f0f0e8,#e0e0d0)
              {%- when 6 -%}linear-gradient(135deg,#f0eeee,#e0d8d8)
              {%- endcase -%}
            ">{{ emoji }}</div>
            <div class="instagram__overlay">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <div class="text-center animate-on-scroll" style="margin-top:var(--sp-10)">
      <a href="https://instagram.com/desknet" class="btn btn--dark" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        Follow @desknet on Instagram
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instagram Gallery",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "url", "label": "Link URL" },
        { "type": "text", "id": "emoji", "label": "Placeholder emoji", "default": "🖥️" }
      ]
    }
  ],
  "presets": [{ "name": "Instagram Gallery" }]
}
{% endschema %}
