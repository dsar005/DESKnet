<!-- Cart Drawer Overlay -->
<div class="cart-drawer__overlay" id="CartOverlay"></div>

<!-- Cart Drawer -->
<div class="cart-drawer" id="CartDrawer" role="dialog" aria-modal="true" aria-label="Shopping cart">

  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      Your Cart
    </h2>
    <button class="cart-drawer__close" data-close-cart aria-label="Close cart">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>
    </button>
  </div>

  <div class="cart-drawer__body" id="CartBody">
    <div class="cart-drawer__empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <h3 class="cart-drawer__empty-title">Your cart is empty</h3>
      <p class="cart-drawer__empty-text">Add some products to get started.</p>
      <a href="/collections/all" class="btn btn--primary btn--sm" data-close-cart style="margin-top:8px">Start Shopping</a>
    </div>
  </div>

  <div class="cart-drawer__footer">
    <p class="cart-drawer__shipping-note">
      🚚 Free shipping on orders over $50!
    </p>
    <div class="cart-drawer__subtotal">
      <span class="cart-drawer__subtotal-label">Subtotal</span>
      <span class="cart-drawer__subtotal-value" id="CartSubtotal">$0.00</span>
    </div>
    <a href="/checkout" class="btn btn--primary cart-drawer__checkout">
      Proceed to Checkout
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round"/></svg>
    </a>
    <button class="cart-drawer__continue" data-close-cart>Continue Shopping</button>
  </div>

</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
