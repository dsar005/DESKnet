<section class="section best-sellers">
  <div class="container">
    <div class="section__header animate-on-scroll">
      <span class="section__eyebrow">Best Sellers</span>
      <h2 class="section__title">The Customer Favorites</h2>
      <p class="section__subtitle">Products our community can't stop recommending. These are the desk upgrades that make a real difference.</p>
    </div>

    <div class="best-sellers__grid">
      {%- for product in section.settings.collection.products limit: 3 -%}
        <div class="animate-on-scroll animate-delay-{{ forloop.index }}">
          {% render 'product-card', product: product, dark: true %}
        </div>
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="animate-on-scroll animate-delay-{{ forloop.index }}">
            {% render 'product-card-placeholder', index: forloop.index, dark: true %}
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <div class="text-center" style="margin-top:var(--sp-12)">
      <a href="/collections/best-sellers" class="btn btn--white btn--lg">
        See All Best Sellers
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Best sellers collection" }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
