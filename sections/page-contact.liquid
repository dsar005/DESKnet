<!-- Contact Hero -->
<div style="background:var(--color-bg-alt);padding:var(--sp-16) 0 var(--sp-8);border-bottom:1px solid var(--color-border)">
  <div class="container">
    <span class="section__eyebrow" style="display:block;text-align:left;margin-bottom:var(--sp-3)">Get in Touch</span>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2.5rem,5vw,4rem);font-weight:800;letter-spacing:-0.03em;margin-bottom:var(--sp-4)">We'd Love to Hear From You</h1>
    <p style="font-size:var(--fs-lg);color:var(--color-text-muted);max-width:500px">Questions, feedback, or partnership inquiries — our team is here and happy to help.</p>
  </div>
</div>

<div class="contact-page">
  <div class="container">
    <div class="contact-page__layout">

      <!-- Form -->
      <div class="animate-on-scroll">
        <div class="contact-form">
          <h2 class="contact-form__title">Send Us a Message</h2>
          <p class="contact-form__intro">We typically respond within 24 hours on weekdays.</p>

          {% form 'contact' %}
            {%- if form.posted_successfully? -%}
              <div style="padding:var(--sp-6);background:#d1fae5;border-radius:var(--radius-lg);border:1px solid #6ee7b7;color:#065f46;margin-bottom:var(--sp-6)">
                <strong>Message sent!</strong> We'll get back to you within 24 hours. Thank you for reaching out.
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div style="padding:var(--sp-4);background:#fee2e2;border-radius:var(--radius);border:1px solid #fca5a5;color:#dc2626;margin-bottom:var(--sp-5)">
                Please check your form for errors and try again.
              </div>
            {%- endif -%}

            <div class="form-group--row">
              <div class="form-group">
                <label class="form-label" for="ContactFirst">First Name *</label>
                <input type="text" id="ContactFirst" name="contact[first_name]" required class="form-input" placeholder="John">
              </div>
              <div class="form-group">
                <label class="form-label" for="ContactLast">Last Name *</label>
                <input type="text" id="ContactLast" name="contact[last_name]" required class="form-input" placeholder="Doe">
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="ContactEmail">Email Address *</label>
              <input type="email" id="ContactEmail" name="contact[email]" required class="form-input" placeholder="you@example.com" value="{{ form.email }}">
            </div>

            <div class="form-group">
              <label class="form-label" for="ContactOrderNum">Order Number (if applicable)</label>
              <input type="text" id="ContactOrderNum" name="contact[order_number]" class="form-input" placeholder="#DN-12345">
            </div>

            <div class="form-group">
              <label class="form-label" for="ContactSubject">Subject *</label>
              <select id="ContactSubject" name="contact[subject]" required class="form-input" style="appearance:none">
                <option value="">Select a topic...</option>
                <option>Order Status / Tracking</option>
                <option>Returns &amp; Refunds</option>
                <option>Product Question</option>
                <option>Shipping Issue</option>
                <option>Wholesale / Partnership</option>
                <option>Press / Media</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="ContactMessage">Message *</label>
              <textarea id="ContactMessage" name="contact[body]" required class="form-textarea" rows="6" placeholder="Tell us how we can help...">{{ form.body }}</textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--full btn--lg">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M22 2L11 13M22 2L15 22 11 13 2 9l20-7z"/></svg>
              Send Message
            </button>
          {% endform %}
        </div>
      </div>

      <!-- Info -->
      <div class="contact-info animate-on-scroll">
        <h2 class="contact-info__title">Contact Information</h2>

        <div class="contact-info__items">
          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="contact-info__item-title">Email Us</div>
              <div class="contact-info__item-text">
                <a href="mailto:hello@desknet.co" style="color:var(--color-accent)">hello@desknet.co</a><br>
                <span style="font-size:var(--fs-xs)">We respond within 24 hours, Mon–Fri</span>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="contact-info__item-title">Support Hours</div>
              <div class="contact-info__item-text">
                Monday – Friday<br>
                9:00 AM – 6:00 PM EST
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="contact-info__item-title">Headquarters</div>
              <div class="contact-info__item-text">
                DESKnet Inc.<br>
                San Francisco, CA 94102<br>
                United States
              </div>
            </div>
          </div>
        </div>

        <!-- FAQ preview -->
        <div style="background:var(--color-bg-alt);border-radius:var(--radius-xl);padding:var(--sp-6);border:1px solid var(--color-border)">
          <h3 style="font-family:var(--font-heading);font-weight:700;font-size:var(--fs-lg);margin-bottom:var(--sp-4)">Quick Answers</h3>
          <div style="display:flex;flex-direction:column;gap:var(--sp-3)">
            {%- assign faqs = "How long does shipping take?|Standard shipping takes 3–7 business days. Express 1–2 days.|What's your return policy?|30-day hassle-free returns. Start at hello@desknet.co.|How do I track my order?|You'll receive a tracking email as soon as your order ships." | split: "|" -%}
            {%- for i in (0..2) -%}
              {%- assign j = i | times: 2 -%}
              <div style="padding:var(--sp-3) 0;border-bottom:1px solid var(--color-border)">
                <div style="font-weight:600;font-size:var(--fs-sm);margin-bottom:var(--sp-1)">{{ faqs[j] }}</div>
                <div style="font-size:var(--fs-sm);color:var(--color-text-muted)">{{ faqs[j | plus: 1] }}</div>
              </div>
            {%- endfor -%}
          </div>
          <a href="/pages/faq" class="btn btn--ghost btn--sm" style="margin-top:var(--sp-5)">View Full FAQ</a>
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": []
}
{% endschema %}
