<footer class="site-footer">
  <div class="container">
    <div class="footer__top">
      <!-- Brand col -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <div class="footer__logo-mark">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="8" width="18" height="11" rx="1.5" fill="white"/>
              <path d="M7 8V6a5 5 0 0110 0v2" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
              <circle cx="12" cy="13.5" r="1.5" fill="#4f46e5"/>
            </svg>
          </div>
          <span class="footer__logo-text">DESK<span>net</span></span>
        </a>
        <p class="footer__tagline">Premium minimal desk accessories for students, developers, and creators. Build the workspace you deserve.</p>
        <div class="footer__social">
          <a href="https://instagram.com/desknet" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href="https://twitter.com/desknet" class="footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4.01c-1 .49-1.98.689-3 .99-1.121-1.265-2.783-1.335-4.38-.737S11.977 6.323 12 8v1c-3.245.083-6.135-1.395-8-4 0 0-4.182 7.433 4 11-1.872 1.247-3.739 2.088-6 2 3.308 1.803 6.913 2.423 10.034 1.517 3.58-1.04 6.522-3.723 7.651-7.742a13.84 13.84 0 00.497-3.753C20.18 7.773 21.692 5.25 22 4.009z"/></svg>
          </a>
          <a href="https://tiktok.com/@desknet" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg>
          </a>
          <a href="https://youtube.com/@desknet" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
        </div>
      </div>

      <!-- Shop col -->
      <div>
        <h4 class="footer__col-title">Shop</h4>
        <ul class="footer__links">
          <li><a href="/collections/all" class="footer__link">All Products</a></li>
          <li><a href="/collections/desk-accessories" class="footer__link">Desk Accessories</a></li>
          <li><a href="/collections/stands-mounts" class="footer__link">Stands &amp; Mounts</a></li>
          <li><a href="/collections/lighting" class="footer__link">Desk Lighting</a></li>
          <li><a href="/collections/organization" class="footer__link">Cable Management</a></li>
          <li><a href="/collections/best-sellers" class="footer__link">Best Sellers</a></li>
          <li><a href="/collections/new-arrivals" class="footer__link">New Arrivals</a></li>
        </ul>
      </div>

      <!-- Support col -->
      <div>
        <h4 class="footer__col-title">Support</h4>
        <ul class="footer__links">
          <li><a href="/pages/faq" class="footer__link">FAQ</a></li>
          <li><a href="/pages/shipping-returns" class="footer__link">Shipping &amp; Returns</a></li>
          <li><a href="/pages/contact" class="footer__link">Contact Us</a></li>
          <li><a href="/account/orders" class="footer__link">Track My Order</a></li>
          <li><a href="/pages/privacy-policy" class="footer__link">Privacy Policy</a></li>
          <li><a href="/pages/terms-of-service" class="footer__link">Terms of Service</a></li>
          <li><a href="/pages/refund-policy" class="footer__link">Refund Policy</a></li>
        </ul>
      </div>

      <!-- Contact col -->
      <div>
        <h4 class="footer__col-title">Contact</h4>
        <div class="footer__contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div>
            <div style="font-size:var(--fs-sm);color:#fff;font-weight:600;margin-bottom:2px">Email</div>
            <a href="mailto:hello@desknet.co" class="footer__link">hello@desknet.co</a>
          </div>
        </div>
        <div class="footer__contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.23 10.9a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.06 6.06l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <div>
            <div style="font-size:var(--fs-sm);color:#fff;font-weight:600;margin-bottom:2px">Support Hours</div>
            <span class="footer__link" style="cursor:default">Mon–Fri, 9am–6pm EST</span>
          </div>
        </div>
        <div class="footer__contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            <div style="font-size:var(--fs-sm);color:#fff;font-weight:600;margin-bottom:2px">Response Time</div>
            <span class="footer__link" style="cursor:default">Within 24 hours</span>
          </div>
        </div>

        <!-- Trust badges in footer -->
        <div style="display:flex;gap:var(--sp-3);margin-top:var(--sp-5);flex-wrap:wrap">
          <div style="display:flex;align-items:center;gap:6px;padding:6px 10px;background:rgba(255,255,255,0.06);border-radius:var(--radius);border:1px solid rgba(255,255,255,0.08)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span style="font-size:11px;color:rgba(255,255,255,0.5);font-weight:500">SSL Secure</span>
          </div>
          <div style="display:flex;align-items:center;gap:6px;padding:6px 10px;background:rgba(255,255,255,0.06);border-radius:var(--radius);border:1px solid rgba(255,255,255,0.08)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span style="font-size:11px;color:rgba(255,255,255,0.5);font-weight:500">4.9★ Rated</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} DESKnet. All rights reserved. Built for workspace enthusiasts worldwide.
      </p>
      <div class="footer__payments">
        {%- assign pay_labels = "Visa,MC,Amex,PayPal,ApplePay,Shop" | split: "," -%}
        {%- for label in pay_labels -%}
          <div class="footer__payment-icon">{{ label }}</div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
