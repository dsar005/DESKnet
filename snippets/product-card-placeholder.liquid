{%- assign card_index = index | default: 1 -%}
{%- assign dark_mode = dark | default: false -%}

{%- assign titles = "Adjustable Laptop Stand|Minimal Desk Mat XL|Cable Management Kit|RGB Desk Light Bar|Wireless Charging Pad" | split: "|" -%}
{%- assign prices = "$49.99|$34.99|$24.99|$39.99|$44.99" | split: "|" -%}
{%- assign compare_prices = "$69.99|$49.99||$54.99|$59.99" | split: "|" -%}
{%- assign emojis = "💻|🖱️|🔌|💡|⚡" | split: "|" -%}
{%- assign review_counts = "247|182|156|98|213" | split: "|" -%}
{%- assign handles = "adjustable-laptop-stand|minimal-desk-mat|cable-management-kit|rgb-desk-light-bar|wireless-charging-pad" | split: "|" -%}

{%- assign i = card_index | minus: 1 -%}
{%- assign title = titles[i] | default: "Premium Desk Accessory" -%}
{%- assign price = prices[i] | default: "$49.99" -%}
{%- assign compare = compare_prices[i] -%}
{%- assign emoji = emojis[i] | default: "🖥️" -%}
{%- assign count = review_counts[i] | default: "100" -%}
{%- assign handle = handles[i] | default: "product" -%}

<div class="product-card{% if dark_mode %} product-card--dark{% endif %}">
  <a href="/products/{{ handle }}" class="product-card__media">
    <div class="product-card__img-placeholder" style="
      {% if dark_mode %}
        background: linear-gradient(135deg, #1a1a2a, #1e1e32);
      {% else %}
        background: linear-gradient(135deg, #f5f5f0, #ebebeb);
      {% endif %}
      font-size: 4rem;
    ">
      {{ emoji }}
    </div>

    {%- if compare != blank -%}
      <div class="product-card__badges">
        <span class="badge badge--sale">Sale</span>
      </div>
    {%- endif -%}

    <div class="product-card__actions">
      <button class="product-card__action" data-wishlist aria-label="Wishlist">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
      </button>
      <button class="product-card__action" data-quick-view="{{ handle }}" aria-label="Quick view">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      </button>
    </div>
  </a>

  <div class="product-card__body">
    <div class="product-card__vendor">DESKnet</div>
    <a href="/products/{{ handle }}" class="product-card__title">{{ title }}</a>
    <div class="product-card__rating">
      <div class="stars">
        {%- for s in (1..5) -%}<svg viewBox="0 0 24 24" fill="#f59e0b" width="12" height="12"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>{%- endfor -%}
      </div>
      <span class="product-card__rating-count">({{ count }})</span>
    </div>
    <div class="product-card__pricing">
      <span class="product-card__price">{{ price }}</span>
      {%- if compare != blank -%}
        <span class="product-card__compare">{{ compare }}</span>
      {%- endif -%}
    </div>
    <a href="/products/{{ handle }}" class="btn btn--primary product-card__add">Add to Cart</a>
  </div>
</div>
