<!-- Cart Page (fallback for non-drawer cart) -->
<div style="padding:var(--sp-16) 0 var(--sp-24)">
  <div class="container container--sm">
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:var(--sp-10)">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <div style="display:grid;grid-template-columns:1fr 380px;gap:var(--sp-12);align-items:start">
        <!-- Items -->
        <div>
          {%- for item in cart.items -%}
            <div style="display:grid;grid-template-columns:100px 1fr;gap:var(--sp-6);padding:var(--sp-6) 0;border-bottom:1px solid var(--color-border)">
              <a href="{{ item.url }}">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" style="width:100%;border-radius:var(--radius-lg)">
                {%- endif -%}
              </a>
              <div>
                <a href="{{ item.url }}" style="font-weight:700;font-size:var(--fs-base);display:block;margin-bottom:var(--sp-1)">{{ item.product_title }}</a>
                {%- if item.variant_title != blank -%}
                  <div style="font-size:var(--fs-sm);color:var(--color-text-muted);margin-bottom:var(--sp-3)">{{ item.variant_title }}</div>
                {%- endif -%}
                <div style="display:flex;align-items:center;justify-content:space-between;gap:var(--sp-4)">
                  <div>{{ item.final_line_price | money }}</div>
                  <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="font-size:var(--fs-xs);color:var(--color-text-muted);text-decoration:underline">Remove</a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- Summary -->
        <div style="background:var(--color-bg-alt);border-radius:var(--radius-xl);padding:var(--sp-8);border:1px solid var(--color-border);position:sticky;top:calc(var(--header-height)+var(--sp-6))">
          <h2 style="font-family:var(--font-heading);font-size:var(--fs-xl);font-weight:700;margin-bottom:var(--sp-6)">Order Summary</h2>
          <div style="display:flex;justify-content:space-between;margin-bottom:var(--sp-3);font-size:var(--fs-sm);color:var(--color-text-muted)">
            <span>Subtotal ({{ cart.item_count }} items)</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div style="display:flex;justify-content:space-between;margin-bottom:var(--sp-3);font-size:var(--fs-sm);color:var(--color-text-muted)">
            <span>Shipping</span>
            <span style="color:var(--color-success);font-weight:600">
              {%- if cart.total_price >= 5000 -%}Free{%- else -%}Calculated at checkout{%- endif -%}
            </span>
          </div>
          <div style="border-top:1px solid var(--color-border);margin:var(--sp-4) 0;padding-top:var(--sp-4);display:flex;justify-content:space-between;font-family:var(--font-heading);font-size:var(--fs-xl);font-weight:800">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <a href="/checkout" class="btn btn--primary btn--full btn--lg" style="margin-top:var(--sp-4)">
            Proceed to Checkout
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round"/></svg>
          </a>
          <a href="/collections/all" style="display:block;text-align:center;font-size:var(--fs-sm);color:var(--color-text-muted);margin-top:var(--sp-4)">Continue Shopping</a>
        </div>
      </div>
    {%- else -%}
      <div style="text-align:center;padding:var(--sp-24) 0">
        <div style="font-size:5rem;margin-bottom:var(--sp-6)">🛒</div>
        <h2 style="font-family:var(--font-heading);font-size:var(--fs-3xl);font-weight:800;margin-bottom:var(--sp-4)">Your cart is empty</h2>
        <p style="color:var(--color-text-muted);font-size:var(--fs-lg);margin-bottom:var(--sp-8)">Looks like you haven't added anything yet. Let's change that!</p>
        <a href="/collections/all" class="btn btn--primary btn--lg">Explore Products</a>
      </div>
    {%- endif -%}
  </div>
</div>
